{
  "name": "sharding-postgres",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "description": "TypeScript playground for raw-SQL PostgreSQL experiments.",
  "scripts": {
    "seed": "tsx scripts/seed.ts",
